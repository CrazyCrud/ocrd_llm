{
  "git_url": "https://github.com/CrazyCrud/ocrd_llm",
  "version": "0.1.0",
  "tools": {
    "ocrd-llm": {
      "executable": "ocrd-llm",
      "input_file_grp_cardinality": 1,
      "output_file_grp_cardinality": 1,
      "categories": ["Text recognition and optimization"],
      "steps": ["recognition/text-recognition"],
      "description": "Text recognition using Academic Cloud models",
      "parameters": {
        "model_id": {
          "description": "Model on f.ex. Academic Cloud",
          "type": "string"
        },
        "api_key": {
          "description": "API key",
          "type": "string"
        },
        "api_endpoint": {
          "description": "OpenAI compatible API endpoint",
          "type": "string"
        },
        "temperature": {
          "description": "Temperature parameter of the model",
          "type": "number",
          "format": "float",
          "default": 0.7
        },
        "prompt_txt_file": {
          "description": "Text file containing a prompt used for the specific model",
          "type": "string",
          "default": "prompt.txt"
        },
        "use_context": {
          "description": "Use containing TextRegion elements additionally to TextLine elements",
          "type": "boolean", 
          "default": false
        }
      }
    }
  }
}